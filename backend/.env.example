
# GLM (Zhipu AI). Si está vacío, se usa Groq.
GLM_API_KEY=
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Groq (fallback gratuito)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio (embeddings gemini-embedding-001 + Gemini vision)
GOOGLE_API_KEY=
# Modelo de visión. Default 'gemini-2.5-flash-lite' (free tier estable).
# Si tu cuenta tiene cuota para 2.0-flash o 2.5-flash, podés cambiarlo.
VISION_MODEL=gemini-2.5-flash-lite

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Langfuse Cloud
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=8

CREADOR_PASSWORD=
APROBADOR_A_PASSWORD=
APROBADOR_B_PASSWORD=

# CORS (lista separada por coma)
CORS_ORIGINS=http://localhost:3000
